.page-recipe {
  padding-bottom: 120rpx;
  min-height: 100vh;
  background: var(--bg);
}

.recipe-search {
  display: flex;
  align-items: center;
  margin: 20rpx 32rpx;
  padding: 20rpx 28rpx;
  background: var(--bg-card);
  border-radius: var(--radius-round);
  box-shadow: 0 4rpx 16rpx rgba(255, 143, 171, 0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: var(--text-hint);
}

.category-tabs {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.tabs-inner {
  display: flex;
  padding: 0 32rpx;
  gap: 16rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  padding: 14rpx 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: var(--bg-card);
  border-radius: var(--radius-round);
  white-space: nowrap;
  transition: all 0.2s;
}

.tab-active {
  color: #FFFFFF;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  box-shadow: 0 6rpx 16rpx rgba(255, 143, 171, 0.35);
  font-weight: 600;
}

.recipe-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 24rpx;
  gap: 20rpx;
}

.recipe-card {
  width: calc(50% - 10rpx);
  background: var(--bg-card);
  border-radius: var(--radius-large);
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(255, 143, 171, 0.1);
  transition: transform 0.2s;
}

.recipe-card:active {
  transform: scale(0.97);
}

.recipe-cover {
  height: 180rpx;
  background: linear-gradient(135deg, #FFF0F5 0%, #FFE4ED 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.cover-emoji {
  font-size: 72rpx;
}

.recipe-tags {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  display: flex;
  gap: 6rpx;
  flex-wrap: wrap;
}

.recipe-mini-tag {
  font-size: 20rpx;
  color: var(--primary-dark);
  background: rgba(255, 255, 255, 0.85);
  padding: 4rpx 12rpx;
  border-radius: var(--radius-round);
}

.recipe-info {
  padding: 16rpx 20rpx 20rpx;
}

.recipe-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.recipe-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 20rpx;
}

.meta-dot {
  font-size: 18rpx;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-text {
  color: var(--text-hint);
  font-size: 22rpx;
}

.fab {
  position: fixed;
  bottom: 140rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  box-shadow: 0 12rpx 32rpx rgba(255, 107, 142, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.fab:active {
  transform: scale(0.9);
}

.fab-icon {
  font-size: 52rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}
