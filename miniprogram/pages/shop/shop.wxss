/* pages/shop/shop.wxss */

.page-shop {
  background: linear-gradient(175deg, #FFF8F9 0%, #FFF5F7 50%, #FFF0F5 100%);
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 积分余额 */
.balance-card {
  margin: 32rpx 32rpx 20rpx;
  position: relative;
  overflow: hidden;
  border-radius: var(--radius-large);
  background: linear-gradient(135deg, #FF8FAB 0%, #FF6B8E 100%);
  box-shadow: 0 8rpx 28rpx rgba(255, 143, 171, 0.35);
}

.balance-bg {
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.balance-bg::after {
  content: '';
  position: absolute;
  bottom: -30rpx;
  left: -60rpx;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.balance-content {
  position: relative;
  z-index: 1;
  padding: 36rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.balance-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
  animation: heartBeat 2s ease-in-out infinite;
}

@keyframes heartBeat {
  0%, 100% { transform: scale(1); }
  15% { transform: scale(1.12); }
  30% { transform: scale(1); }
}

.balance-info {
  display: flex;
  align-items: baseline;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.balance-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.balance-num {
  font-size: 60rpx;
  font-weight: 800;
  color: white;
  line-height: 1;
}

.balance-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 功能区 */
.shop-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 28rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 0;
  background: white;
  border-radius: var(--radius);
  border: 1rpx solid var(--border-light);
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.03);
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.action-btn::after { border: none; }

.action-btn.secondary {
  background: var(--bg-light);
  border-color: transparent;
}

.action-btn-icon {
  font-size: 28rpx;
}

.action-btn-text {
  font-size: 26rpx;
}

/* 商品网格 */
.section-header {
  padding: 0 32rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.section-hint {
  font-size: 24rpx;
  color: var(--text-hint);
}

.shop-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 32rpx;
  gap: 16rpx;
}

.shop-card {
  width: calc(50% - 8rpx);
  background: white;
  border-radius: var(--radius-large);
  padding: 28rpx 20rpx 24rpx;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 2rpx 14rpx rgba(0, 0, 0, 0.04);
  border: 1rpx solid var(--border-light);
}

.card-delete {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.04);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-hint);
  z-index: 2;
}

.card-icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFF0F5 0%, #FFE4ED 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.card-icon {
  font-size: 48rpx;
}

.card-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

.card-cost {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 18rpx;
}

.cost-icon {
  font-size: 22rpx;
}

.cost-num {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--primary-dark);
}

.redeem-btn {
  width: 100%;
  padding: 16rpx 0;
  border-radius: var(--radius-round);
  background: linear-gradient(135deg, #FF8FAB 0%, #FF6B8E 100%);
  color: white;
  font-size: 26rpx;
  font-weight: 600;
  border: none;
  box-shadow: 0 4rpx 14rpx rgba(255, 143, 171, 0.25);
}

.redeem-btn::after { border: none; }

.redeem-btn.disabled {
  background: #E5E5E5;
  color: #999;
  box-shadow: none;
}

/* ====== 弹窗 ====== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 100;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-sheet.show {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 32rpx 20rpx;
  border-bottom: 1rpx solid var(--border-light);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 44rpx;
  color: var(--text-hint);
  padding: 0 8rpx;
}

.modal-body {
  padding: 28rpx 32rpx;
}

.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 14rpx;
}

.form-input {
  width: 100%;
  padding: 20rpx 24rpx;
  background: var(--bg-light);
  border-radius: var(--radius);
  font-size: 28rpx;
  box-sizing: border-box;
}

.icon-picker {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.icon-option {
  width: 76rpx;
  height: 76rpx;
  border-radius: var(--radius);
  background: var(--bg-light);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.icon-option.selected {
  border-color: var(--primary);
  background: var(--secondary);
  transform: scale(1.1);
}

.modal-footer {
  padding: 16rpx 32rpx 40rpx;
}

.modal-footer .btn-primary {
  width: 100%;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx 0;
}

/* 兑换记录 */
.redeem-log-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-light);
}

.redeem-log-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.redeem-log-name {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.redeem-log-time {
  font-size: 22rpx;
  color: var(--text-hint);
}

.redeem-log-cost {
  font-size: 28rpx;
  font-weight: 700;
  color: #FF6B8E;
}

/* 空状态 */
.empty-state {
  padding: 100rpx 0;
}
