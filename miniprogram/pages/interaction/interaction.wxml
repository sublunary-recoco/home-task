<view class="page-interaction">

  <!-- 顶部：情侣卡片 -->
  <view class="hero-section">
    <!-- 装饰背景纹理 -->
    <view class="hero-bg-pattern"></view>

    <!-- 天数丝带 -->
    <view class="days-ribbon">
      <view class="ribbon-tail ribbon-tail-left"></view>
      <view class="ribbon-body">
        <text class="ribbon-label">我们已经在一起</text>
        <view class="ribbon-count">
          <text class="ribbon-num">{{togetherDays}}</text>
          <text class="ribbon-unit">天</text>
        </view>
      </view>
      <view class="ribbon-tail ribbon-tail-right"></view>
    </view>

    <!-- 双人头像 -->
    <view class="hero-avatars">
      <view class="avatar-frame avatar-left">
        <view class="avatar-ring"></view>
        <image class="avatar-img" src="{{familyInfo && familyInfo.members && familyInfo.members[0] && familyInfo.members[0].avatarUrl ? familyInfo.members[0].avatarUrl : '/images/avatar.png'}}" mode="aspectFill" />
        <text class="avatar-crown">👑</text>
      </view>

      <view class="hero-heart-wrap">
        <text class="hero-heart">💗</text>
        <view class="heart-sparkle sparkle-1">✨</view>
        <view class="heart-sparkle sparkle-2">💕</view>
        <view class="heart-sparkle sparkle-3">💫</view>
      </view>

      <view class="avatar-frame avatar-right">
        <view class="avatar-ring"></view>
        <image class="avatar-img" src="{{familyInfo && familyInfo.members && familyInfo.members[1] && familyInfo.members[1].avatarUrl ? familyInfo.members[1].avatarUrl : '/images/avatar.png'}}" mode="aspectFill" />
        <text class="avatar-heart-deco">💝</text>
      </view>
    </view>

    <!-- 下方丝带 -->
    <view class="hero-subtitle">
      <text class="subtitle-deco left-deco">· · ·</text>
      <text class="subtitle-text">爱在日常，才不寻常</text>
      <text class="subtitle-deco right-deco">· · ·</text>
    </view>
  </view>

  <!-- 签到区 -->
  <view class="checkin-section">
    <view class="section-label">
      <text class="label-dot"></text>
      <text class="label-text">每日签到</text>
    </view>

    <view class="checkin-card">
      <!-- 装饰胶带 -->
      <view class="washi-tape tape-top"></view>

      <view class="checkin-body">
        <!-- 签到按钮 -->
        <button class="checkin-btn-main {{checkedIn ? 'is-checked' : ''}}" bindtap="handleCheckIn" disabled="{{checkedIn}}">
          <view class="checkin-btn-inner">
            <text class="checkin-btn-icon">{{checkedIn ? '✅' : '📝'}}</text>
            <view class="checkin-btn-texts">
              <text class="checkin-btn-title">{{checkedIn ? '今日已签到' : '点击签到'}}</text>
              <text class="checkin-btn-sub">{{checkedIn ? '明天再来吧 ~' : '开始美好的一天'}}</text>
            </view>
          </view>
          <!-- 签到按钮装饰波纹 -->
          <view wx:if="{{!checkedIn}}" class="btn-ripple"></view>
        </button>

        <!-- 连续签到 -->
        <view class="streak-display">
          <view class="streak-flame {{streak >= 7 ? 'fire-big' : ''}}">
            <text class="flame-icon">{{streak >= 30 ? '🔥' : streak >= 7 ? '🌟' : streak >= 3 ? '✨' : '💫'}}</text>
          </view>
          <view class="streak-info">
            <text class="streak-num">{{streak}}</text>
            <text class="streak-label">连续签到天数</text>
          </view>
          <!-- 里程碑 -->
          <view wx:if="{{streak >= 7}}" class="streak-badge">
            <text>{{streak >= 30 ? '月度达人' : '周度全勤'}}</text>
          </view>
        </view>

        <!-- 签到提示 -->
        <view class="checkin-tip" wx:if="{{!checkedIn}}">
          <text class="tip-icon">🎁</text>
          <text class="tip-text">签到随机获得 1~5 爱心值</text>
        </view>
      </view>

      <!-- 装饰胶带底部 -->
      <view class="washi-tape tape-bottom"></view>
    </view>
  </view>

  <!-- 今日夸夸 -->
  <view class="compliment-section">
    <view class="section-label">
      <text class="label-dot"></text>
      <text class="label-text">今日夸夸</text>
    </view>

    <view class="compliment-card">
      <!-- 手账边框装饰 -->
      <view class="journal-dots">
        <view wx:for="{{[1,2,3,4,5,6,7,8]}}" wx:key="*this" class="journal-dot"></view>
      </view>
      <text class="compliment-date">📅 {{checkedIn ? '今天' : '新的一天'}}</text>
      <view class="compliment-content">
        <text class="compliment-quote-mark">"</text>
        <text class="compliment-text">{{compliment || '爱是一起吃很多顿饭，也是一起做好多小事'}}</text>
        <text class="compliment-quote-mark end">"</text>
      </view>
      <view class="compliment-footer">
        <text class="compliment-from">— 来自你的 TA 💌</text>
      </view>
    </view>
  </view>

  <!-- 签到历史 -->
  <view class="history-section">
    <view class="section-label">
      <text class="label-dot"></text>
      <text class="label-text">签到记录</text>
    </view>

    <view wx:if="{{logs.length > 0}}" class="history-list">
      <view wx:for="{{logs}}" wx:key="_id" class="history-card">
        <!-- 时间轴 -->
        <view class="timeline">
          <view class="timeline-dot {{index === 0 ? 'latest' : ''}}"></view>
          <view wx:if="{{index < logs.length - 1}}" class="timeline-line"></view>
        </view>

        <view class="history-body">
          <view class="history-header flex-between">
            <view class="history-date-wrap">
              <text class="history-day">{{item.date}}</text>
              <text wx:if="{{item.streak >= 7}}" class="history-badge">连续{{item.streak}}天</text>
            </view>
            <text class="history-score">+{{item.score}}</text>
          </view>
          <text class="history-remark">签到获得 {{item.score}} 爱心值 ❤️</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-icon">📝</text>
      <text class="empty-text">还没有签到记录</text>
      <text class="empty-sub text-hint">快来签到获取爱心值吧~</text>
    </view>
  </view>

</view>
