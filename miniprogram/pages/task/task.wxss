.page-task {
  padding-bottom: 120rpx;
  background: var(--bg);
}

.task-tabs {
  position: sticky;
  top: 0;
  z-index: 10;
  background: var(--bg);
  padding: 20rpx 0 16rpx;
}

.tabs-scroll {
  white-space: nowrap;
  padding: 0 32rpx;
}

.tab {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  background: var(--bg-card);
  border-radius: var(--radius-round);
  transition: all 0.3s;
  font-weight: 500;
}

.tab.active {
  background: linear-gradient(135deg, #FF8FAB 0%, #FF6B8E 100%);
  color: white;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 143, 171, 0.35);
}

.task-list {
  padding: 0 32rpx;
}

.task-card {
  margin: 0 0 20rpx 0;
}

.task-header {
  margin-bottom: 16rpx;
}

.task-avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--secondary);
  margin-right: 12rpx;
}

.task-creator-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.task-body {
  margin-bottom: 16rpx;
}

.task-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
  color: var(--text-primary);
}

.task-desc {
  font-size: 26rpx;
  line-height: 1.5;
  display: block;
  color: var(--text-secondary);
}

.task-meta {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border);
  margin-bottom: 20rpx;
}

.task-score {
  font-size: 28rpx;
  color: var(--primary-dark);
  font-weight: 700;
  margin-right: 24rpx;
}

.task-deadline {
  font-size: 24rpx;
  color: var(--text-hint);
}

.text-sm {
  font-size: 24rpx;
}

.task-actions {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.task-actions .btn-primary {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.task-actions .btn-secondary {
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.done-text {
  font-size: 28rpx;
  color: #34D399;
  font-weight: 600;
}

.cancel-text {
  font-size: 28rpx;
  color: var(--text-hint);
}

.create-btn {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 108rpx;
  height: 108rpx;
  background: linear-gradient(135deg, #FF8FAB 0%, #FF6B8E 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 142, 0.45);
  z-index: 100;
}

.create-icon {
  font-size: 52rpx;
  color: white;
  line-height: 1;
}

.empty-state {
  padding: 120rpx 0;
}

/* 编辑弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 200;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.edit-sheet {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: white;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 201;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  display: flex;
  flex-direction: column;
  max-height: 75vh;
  overflow-x: hidden;
}

.edit-sheet.show {
  transform: translateY(0);
}

.edit-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 36rpx 32rpx 20rpx;
  border-bottom: 1rpx solid var(--border-light);
  flex-shrink: 0;
}

.edit-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.edit-close {
  font-size: 44rpx;
  color: var(--text-hint);
  padding: 0 8rpx;
}

.edit-body {
  padding: 24rpx 32rpx;
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  max-height: 50vh;
  box-sizing: border-box;
}

.edit-field {
  margin-bottom: 22rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.edit-field-label {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.edit-field-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--bg-light);
  border-radius: var(--radius);
  font-size: 28rpx;
  box-sizing: border-box;
  line-height: 80rpx;
}

.edit-field-textarea {
  width: 100%;
  height: 140rpx;
  padding: 18rpx 24rpx;
  background: var(--bg-light);
  border-radius: var(--radius);
  font-size: 28rpx;
  box-sizing: border-box;
}

.edit-field-row {
  display: flex;
  gap: 16rpx;
  align-items: stretch;
}

.edit-field.half {
  flex: 1;
  margin-bottom: 0;
  min-width: 0;
}

.edit-field.half .edit-field-input {
  font-size: 28rpx;
}

.picker-input {
  display: flex;
  align-items: center;
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--bg-light);
  border-radius: var(--radius);
  color: var(--text-primary);
  box-sizing: border-box;
}

.placeholder-text {
  color: var(--text-hint);
}

.edit-footer {
  padding: 16rpx 32rpx 40rpx;
  flex-shrink: 0;
  border-top: 1rpx solid var(--border-light);
}

.edit-footer .btn-primary {
  width: 100%;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 26rpx 0;
}
