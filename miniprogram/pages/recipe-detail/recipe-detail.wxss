.page-detail {
  min-height: 100vh;
  background: var(--bg);
  padding-bottom: 140rpx;
}

.detail-header {
  background: linear-gradient(180deg, #FFF0F5 0%, var(--bg) 100%);
  padding: 40rpx 32rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE4ED 0%, #FFD4E0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 143, 171, 0.2);
}

.cover-emoji {
  font-size: 90rpx;
}

.header-info {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.detail-name {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.edit-badge {
  padding: 8rpx 24rpx;
  border-radius: var(--radius-round);
  background: var(--secondary);
  color: var(--primary-dark);
  font-size: 24rpx;
  font-weight: 500;
  border: 2rpx solid var(--primary-light);
  flex-shrink: 0;
}

.detail-tags {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.detail-tag {
  font-size: 22rpx;
  color: var(--primary-dark);
  background: rgba(255, 143, 171, 0.12);
  padding: 6rpx 20rpx;
  border-radius: var(--radius-round);
}

.detail-badges {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  line-height: 1;
}

.badge-icon {
  font-size: 26rpx;
  line-height: 1;
}

.badge-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  line-height: 1;
}

.difficulty-star {
  font-size: 26rpx;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--border-light);
}

.title-icon {
  font-size: 36rpx;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.ingredient-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ingredient-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #FAFAFA;
}

.ingredient-item:last-child {
  border-bottom: none;
}

.ingredient-check {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 28rpx;
}

.ingredient-check.checked {
  opacity: 0.5;
}

.ingredient-name {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
}

.ingredient-amount {
  font-size: 26rpx;
  color: var(--text-hint);
  font-weight: 500;
  flex-shrink: 0;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.step-item {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.step-num-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.step-desc {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.8;
}

.tips-content {
  padding: 20rpx;
  background: #FFF9E6;
  border-radius: var(--radius);
  border-left: 6rpx solid var(--accent-yellow);
}

.tips-content text {
  font-size: 26rpx;
  color: #8B6914;
  line-height: 1.8;
}

.detail-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: var(--bg-card);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.btn-cook {
  width: 100%;
  font-size: 34rpx;
  font-weight: 600;
  padding: 28rpx 0;
  border-radius: var(--radius-round);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.btn-fridge-link {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 16rpx 0;
  font-size: 24rpx;
  color: var(--accent-green);
}

.fridge-link-icon {
  font-size: 28rpx;
}
